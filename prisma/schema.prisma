generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  CLICK
  PAYME
  CARD
}

enum Unit {
  LITRE
  M3
  KWH
  KG
}

enum FuelCategory {
  PETROL
  GAS
  PROPANE
  ELECTRICITY
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id                  Int                  @id @default(autoincrement())
  phone               String               @unique
  password            String?
  firstName           String?
  lastName            String?
  wasBorn             DateTime?
  isVerified          Boolean              @default(false)
  roleId              Int
  role                Role                 @relation(fields: [roleId], references: [id])
  sessions            Session[]
  otpCodes            OtpCode[]
  userCars            UserCar[]
  Cars                Car[]
  fuelSessions        FuelSession[]
  resetTokens         PasswordResetToken[]
  registrationTokens  RegistrationToken[]
  cards               Card[]
  paymentTransactions PaymentTransaction[]
  fuelStationLikes    FuelStationLike[]
  Notification        Notification[]
  UserDevice          UserDevice[]
  cashierStations     FuelStation[]        @relation("CashierStation")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model OtpCode {
  id            Int      @id @default(autoincrement())
  code          String
  phone         String
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  expiresAt     DateTime
  isUsed        Boolean  @default(false)
  attemptsCount Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([phone])
  @@index([userId])
}

model RegistrationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String // hashed
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String // hashed
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Car {
  id          Int       @id @default(autoincrement())
  createdById Int?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  brand       String
  model       String
  year        Int?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userCars    UserCar[]

  @@unique([brand, model, year])
  @@index([brand])
  @@index([model])
  @@index([year])
  @@index([createdById])
}

model UserCar {
  id          Int      @id @default(autoincrement())
  userId      Int
  carId       Int
  plateNumber String?  @unique
  vin         String?  @unique
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  car          Car           @relation(fields: [carId], references: [id])
  fuelSessions FuelSession[]

  @@index([userId])
  @@index([carId])
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  refreshToken String // store hashed
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

enum ConnectorStatus {
  AVAILABLE
  OCCUPIED
  OUT_OF_SERVICE
}

enum SessionStatus {
  PENDING
  CONFIRMED
  DISPENSING
  COMPLETED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  SUCCESS
  FAILED
}

model Operator {
  id           Int              @id @default(autoincrement())
  title        String
  color        String?
  contact      String?
  bankName     String?
  bankAccount  String?
  bankMfo      String?
  fuelStations FuelStation[]
  payouts      OperatorPayout[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([title])
}

model FuelStation {
  id               Int               @id @default(autoincrement())
  operatorId       Int
  operator         Operator          @relation(fields: [operatorId], references: [id])
  title            String
  address          String?
  latitude         Float
  longitude        Float
  isActive         Boolean           @default(true)
  image            String?
  workingHours     String?
  fuelPumps        FuelPump[]
  fuelStationLikes FuelStationLike[]
  fuelSessions     FuelSession[]
  cashiers         User[]              @relation("CashierStation")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([operatorId])
}

model FuelPump {
  id             Int                 @id @default(autoincrement())
  stationId      Int
  fuelStation    FuelStation         @relation(fields: [stationId], references: [id])
  fuelPumpNumber Int                 @default(1)
  status         ConnectorStatus     @default(AVAILABLE)
  fuels          FuelPumpFuel[]
  fuelSessions   FuelSession[]
  statusLogs     FuelPumpStatusLog[]
  qrCode         String?             @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([stationId, fuelPumpNumber])
  @@index([stationId])
  @@index([qrCode])
}

model FuelType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  octane    String?
  unit      Unit         @default(LITRE)
  category  FuelCategory @default(PETROL)
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fuelPumpFuels FuelPumpFuel[]
  fuelSessions  FuelSession[]
}

model FuelPumpStatusLog {
  id         Int             @id @default(autoincrement())
  fuelPumpId Int
  fuelPump   FuelPump        @relation(fields: [fuelPumpId], references: [id])
  status     ConnectorStatus
  timestamp  DateTime        @default(now())
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([fuelPumpId])
}

model FuelPumpFuel {
  id           Int       @id @default(autoincrement())
  fuelPumpId   Int
  fuelPump     FuelPump  @relation(fields: [fuelPumpId], references: [id])
  fuelTypeId   Int
  fuelType     FuelType  @relation(fields: [fuelTypeId], references: [id])
  price        Float
  nozzleNumber Int?
  endTime      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([fuelPumpId])
  @@index([fuelTypeId])
}

model FuelSession {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  fuelStationId Int
  fuelStation   FuelStation   @relation(fields: [fuelStationId], references: [id])
  fuelPumpId    Int
  fuelPump      FuelPump      @relation(fields: [fuelPumpId], references: [id])
  fuelTypeId    Int
  fuelType      FuelType      @relation(fields: [fuelTypeId], references: [id])
  userCarId     Int?
  userCar       UserCar?      @relation(fields: [userCarId], references: [id])
  quantity      Float         @default(0) // replaces volume
  unit          Unit          @default(LITRE)
  pricePerUnit  Float         @default(0)
  totalAmount   Float         @default(0) // replaces cost
  status        SessionStatus @default(PENDING)
  startTime     DateTime      @default(now())
  endTime       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payment   PaymentTransaction? @relation(fields: [paymentId], references: [id])
  paymentId Int?                @unique

  @@index([userId])
  @@index([fuelStationId])
  @@index([fuelPumpId])
  @@index([fuelTypeId])
  @@index([userCarId])
}

model PaymentTransaction {
  id           Int            @id @default(autoincrement())
  cardId       Int
  card         Card           @relation(fields: [cardId], references: [id])
  amount       Float
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  provider     String?
  method       PaymentMethod?
  status       PaymentStatus  @default(PENDING)
  externalId   String?        @unique
  errorCode    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  FuelSession FuelSession?

  @@index([userId])
  @@index([cardId])
}

model OperatorPayout {
  id         Int          @id @default(autoincrement())
  operatorId Int
  operator   Operator     @relation(fields: [operatorId], references: [id])
  amount     Decimal
  currency   String       @default("UZS")
  status     PayoutStatus @default(PENDING)
  periodFrom DateTime?
  periodTo   DateTime?
  paidAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([operatorId])
}




model LegalDocument {
  id       Int               @id @default(autoincrement())
  type     LegalDocumentType
  version  String
  isActive Boolean           @default(true)

  translations LegalTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model LegalTranslation {
  id         Int      @id @default(autoincrement())
  documentId Int
  language   Language
  title      String
  content    String   @db.Text

  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language])
  @@index([language])
}

enum LegalDocumentType {
  TERMS
  PRIVACY
}

enum Language {
  UZ
  RU
  EN
}

model FuelStationLike {
  id            Int @id @default(autoincrement())
  userId        Int
  fuelStationId Int

  user        User        @relation(fields: [userId], references: [id])
  fuelStation FuelStation @relation(fields: [fuelStationId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, fuelStationId])
  @@index([fuelStationId])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserDevice {
  id          Int      @id @default(autoincrement())
  userId      Int
  deviceToken String   @unique
  platform    String // ANDROID | IOS
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ==========================================
// Click Integration Models
// ==========================================

model Card {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  last4     String // e.g. 3456
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  PaymentTransaction PaymentTransaction[]

  @@index([userId])
}
